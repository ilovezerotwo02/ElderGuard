# Application Configuration
APP_NAME=ElderGuard
APP_VERSION=1.0.0
DEBUG=True
SECRET_KEY=your-secret-key-change-in-production

# Database Configuration
DATABASE_URL=sqlite+aiosqlite:///./elderguard.db

# LLM Configuration
OPENAI_API_KEY=your-openai-api-key
OPENAI_API_BASE=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-3.5-turbo
EMBEDDING_MODEL_NAME=text-embedding-ada-002

# Local Model Configuration (optional)
LOCAL_MODEL_PATH=./models
USE_LOCAL_MODEL=False
LOCAL_MODEL_NAME=facebook/bart-large-mnli

# Threat Intelligence API
THREAT_INTEL_API_KEY=your-threat-intel-api-key
THREAT_INTEL_API_URL=https://api.threatintel.com/v1

# Audio Detection Configuration
AUDIO_SAMPLE_RATE=16000
AUDIO_DETECTION_THRESHOLD=0.75

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/elderguard.log
